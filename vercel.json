{
  "version": 2,
  "builds": [
    {
      "src": "project_config/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "project_config/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "project_config.settings",
    "PYTHONPATH": "${PYTHONPATH}:.",
    "DEBUG": "False"
  }
}