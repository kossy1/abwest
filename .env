# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_DB_NAME=adaptive_learning
MONGODB_COLLECTION_USERS=users
MONGODB_COLLECTION_COURSES=courses
MONGODB_COLLECTION_QUESTIONS=questions
MONGODB_COLLECTION_QUIZZES=quiz_attempts
MONGODB_COLLECTION_PROGRESS=progress

# Authentication
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=3600  # 1 hour

# AI APIs
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
COHERE_API_KEY=xxxxxxxxxxxxxxxx

# Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Deployment
ENVIRONMENT=development
DEBUG=True